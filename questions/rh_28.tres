[ext_resource type="Script" uid="uid://d11s7unngcflm" path="res://questions/Question.gd" id="1_thbjv"]

[resource]
script = ExtResource("1_thbjv")
question = "Корисник је недавно преместио графичку картицу са рачунара (Рачунар1) на коме је без
проблема функционисала на други рачунар (Рачунар2). Рачунар2 ради без проблема
када корисник прегледава електронску пошту, претражује интернет или када користи
одређене апликације. Међутим, када игра игре које су графички захтевне, после пар
минута рачунар се искључи. Анализирали сте проблем и дошли до закључка да је
највероватнији узрок проблема:"
a = "Снага напајања"
b = "Видео RAM"
c = "Фреквенција CPU-a"
d = "Резолуција монитора"
metadata/_custom_type_script = "uid://d11s7unngcflm"
