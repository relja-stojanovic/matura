[ext_resource type="Script" uid="uid://d11s7unngcflm" path="res://questions/Question.gd" id="1_sx5mm"]

[resource]
script = ExtResource("1_sx5mm")
question = "Позвани сте да конфигуришете бежичну везу за кућну канцеларију. Корисник жели да спречи друге да приступе бежичној мрежи. Корисник има мали број уређаја на мрежи и не жели да памти компликовану лозинку. Да бисте испунили корисникове захтеве ви ћете:"
a = "омогућити MAC filtering"
b = "онемогућите SSID broadcast"
c = "доделити статичке IP адресе"
d = "искључити Content filtering"
metadata/_custom_type_script = "uid://d11s7unngcflm"
