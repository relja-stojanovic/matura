[ext_resource type="Script" uid="uid://d11s7unngcflm" path="res://Question.gd" id="1_syt5n"]

[resource]
script = ExtResource("1_syt5n")
question = "Конфигуришете рачунар за корисника који не зна много о рачунарима. Зато сте за њега креирали стандардни кориснички налог са корисничким именом nikola. Корисник жели да ручно ажурира Windows. Да бисте му омогућили овај захтев потребно је да:"
a = "конфигуришите параметар локалне групну полисе за Windows Update, тако да корисник nikola има право да ручно ажурира Windows"
b = "објасните кориснику како да се пријави на рачунар са администраторског налога"
c = "подесите да ажурирање Windowsa може да уради било који кориснички налог"
metadata/_custom_type_script = "uid://d11s7unngcflm"
