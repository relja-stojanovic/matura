question = "Креиран директоријумски сервис у мрежи:"
a = "Омогућава централизовану аутентификацију корисника унутар домена"
b = "Дозвољава корисницима да користе све рачунаре придружене домену"
c = "Онемогућава коришћење рачунара пријављивањем локалног корисника"
d = "Не допушта да корисник буде члан више група из различитих домена у оквиру шуме"
e = "Дозвољава да локални корисници рачунара користе ресурсе домена"
