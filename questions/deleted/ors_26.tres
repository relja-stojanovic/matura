[resource]
script = ExtResource("1_aoqgo")
question = "Корисник са корисичким именом asistent1 у одељењу Маркетинга безуспешно
покушава да придружи рачунар PC1 домену bookstore.com.
Шеф маркетинга вам се обраћа са захтевима: да кориснику asistent1 омогућите да
рачунар PC1 придружи домену, али да никаква додатна права кориник асиситент не
сме да добије, осим оних која су потребана да заврши овај задатак.
Да бисте испунили постављене захтеве:"
a = "додаћете корисника asistent1 у групу Domain Administrators за кратко време потребно да корисник придружи рачунар домену"
b = "додаћете корисника asistent1 у групу Server Operators"
c = "креираћете на домену bookstore.com рачунарски налог PC1, и дозволићете кориснику asistent1 да придружи рачунар домену"
d = "дозволићете кориснику asistent1 да се локално пријави на домен користећи групне полисе"
answer = Array[int]([2])
metadata/_custom_type_script = "uid://d11s7unngcflm"
