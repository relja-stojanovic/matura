[ext_resource type="Script" uid="uid://d11s7unngcflm" path="res://Question.gd" id="1_g0jki"]

[resource]
script = ExtResource("1_g0jki")
question = "Запослени у програмерској фирми се жале да имају проблем са бежичном мрежом у кантини. Мрежа је непоуздана, након успостављања везе, врло брзо долази до њеног прекида. На другим местима ради без проблема. Највероватнији узрок проблема је:"
a = "микроталасна рерна која постоји у кантини"
b = "Bluetooth миш једног од корисника"
c = "даљински управљач пројектора у сали која се налази одмах поред"
d = "мутилица за инстант кафу"
metadata/_custom_type_script = "uid://d11s7unngcflm"
