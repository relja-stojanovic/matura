script = ExtResource("1_1cnnr")
question = "Да бисте уклонили Активни директоријум са контролера домена са називом DC1 потребно је да:"
a = "покренете команду adRemove DC1"
b = "покренете команду dcpromo, и уклоните улогу Active Directory Domain Services"
c = "покренете команду dsrm /ad: DC1"
d = "ресетујете администаторски налог контролера домена у конзоли Active Directory Users and Computers"
answer = Array[int]([1])
