[resource]
script = ExtResource("1_v8bns")
question = "Планирате да рачунар са инсталираним Windows оперативним системом искористите за креирање слике коју ћете искористити за инсталирање 100 нових рачунара. Да бисте припремили рачунар за креирање слике потребно је да:"
a = "покренете Package Manager"
b = "покренете услужни програм System Preparation"
c = "инсталирате услужни програм User State Migration"
d = "инсталирате Windows Automated Installation Kit"
answer = Array[int]([1])
metadata/_custom_type_script = "uid://d11s7unngcflm"
