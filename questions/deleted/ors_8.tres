script = ExtResource("1_aiekt")
question = "Сервисни пакет (service pack) je:"
a = "колекција ажурирања софтвера"
b = "облик шпијунског софтвера"
c = "режим напајања дизајниран да обезбеди напајање у нужди током нестанка струје"
d = "колекција позадина радне површине, звукова и тема које можете пронаћи на мрежи, а затим преузети и инсталирати на свој систем"
