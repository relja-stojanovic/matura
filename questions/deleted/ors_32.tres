[ext_resource type="Script" uid="uid://d11s7unngcflm" path="res://Question.gd" id="1_hl786"]

[resource]
script = ExtResource("1_hl786")
question = "Сања је техничар који често путује са својом рачунарском опремом у крајеве са екстремним временским условима. Управо је добила позив да отпутује у град који има суву, топлу и прашњаву климу. Пита вас за савет како да заштити опрему. Препоручићете јој да понесе:"
a = "грејна тела"
b = "лименке са компресованим ваздухом"
c = "додатна кућишта за рачунаре"
d = "резервне каблове"
e = "овлаживач ваздуха"
f = "резервоаре са кисеоником"
answer = Array[int]([1, 4])
metadata/_custom_type_script = "uid://d11s7unngcflm"
