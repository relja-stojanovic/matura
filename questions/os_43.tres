[resource]
script = ExtResource("1_qxc4m")
question = "Приликом конфигурисања резервног копирања (бекапа) података на Windows радној станици могуће је одабрати следеће опције:"
a = "резервно копирање може да се врши на диск тог рачунара или на диск умрежи"
b = "резервно копирање може да се конфигурише само за фајл, не може за фолдер"
c = "резервно копирање може да се конфигурише да се обавља једном месечно"
d = "на радној станици не може да се конфигурише резервно копирање, може само насерверу"
e = "на радној станици не може да се конфигурише резервно копирање комплетнограчунара"
answer = Array[int]([0, 2])
