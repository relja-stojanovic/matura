script = ExtResource("1_b6f64")
question = "Распаковали сте нови рачунар, прикључили га на извор непрекидног напајања (UPS) и
повезали тражене периферне уређаје. По стартовању рачунара установили сте да се
светла рачунара и вентилатори укључују, али чујете три гласна, узастопна звучна
сигнала током покретања. Да бисте решили проблем ви ћете:"
a = "заменити напајање"
b = "заменити извор непрекидног напајања (UPS)"
c = "заменити CMOS батерију"
d = "поново поставити RАМ"
answer = Array[int]([3])
