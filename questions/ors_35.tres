[resource]
script = ExtResource("1_hfsml")
question = "Систем који ради беспрекорно, одједном почиње да прави проблеме. Претпоставка је да узрок могу бити корумпирани управљачки програми/драјвери. Линијске команде које се могу користити да се тестира претпостављени узрок проблема су:"
a = "sfc.exe /scannow"
b = "gpedit.mas"
c = "driverquery.exe /si"
d = "sigverif.exe"
e = "regedit.exe"
f = "msconfig.exe"
answer = Array[int]([0, 2, 3])
metadata/_custom_type_script = "uid://d11s7unngcflm"
