[resource]
script = ExtResource("1_5w845")
question = "Шеф рачуноводства предузећа у коме одржавате рачунаре и мрежу пријављује проблем у раду рачунара на коме је инсталирана база података за обраду плата. Када се покрене апликација за обрачун плата, рачунар се знатно успори и не може да се покрене ни један други програм. Рачунар је следеће конфигурације:
● Intel Celeron са 4 језгра
● 4 GB RAM меморије
● два SSD сиска
● диск 0 има ознаку C:
● диск 1 има ознаку D:
● странична датотека од 1.5 GB смештена је на C партицији
● PSI 1Gbps мрежну картицу.
Да бисте отклонили проблем користите Reliability and Performance Monitor и пратите
перформансе рачунара.
Када је апликација покренута уочавате:
● да је проценат коришћења свих процесора 100%
● да постоји знатан број грешака страничења.
Када апликација није покренута:
● просечна искоришћеност процесора је 30%
● и даље постоји значајан број грешака страничења.
На основу добијених извештаја закључујете да је најбоље решење за оптимизацију рада рачунара да:
"
a = "надоградите процесор"
b = "додате RAM меморију"
c = "конфигуришете систем тако да се странична датотека налази на D i E дисковима"
d = "повећате величину страничне датотеке на 3 GB."
answer = Array[int]([0, 1])
metadata/_custom_type_script = "uid://d11s7unngcflm"
