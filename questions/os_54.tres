[resource]
script = ExtResource("1_7jao0")
question = "Радник Милан Марковић на свом рачунару PC1 користи корисничко име milan. Овај
налог је члан групе Nastavnici. За фолдер zadaci подешене су дозволе као на слици.
Дозволе за групе које нису приказане су наслеђене са системског диска. Када Милан
Марковић са другог рачунара покуша да приступи фолдеру zadaci, Милан:"
a = "ће моћи да отвори фолдер и мења садржај фолдера"
b = "неће моћи да отвори фолдер"
c = "ће моћи да отвори, али неће моћи да мења садржај фолдера"
answer = Array[int]([2])
metadata/_custom_type_script = "uid://d11s7unngcflm"
