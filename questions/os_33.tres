[resource]
script = ExtResource("1_wvjfi")
question = "Групи Menadzeri доделили сте Full Control NTFS дозволу за датотеку
C:\\Documents\\Projekti.doc. Премештате ову датотеку у директоријум C:\\Poverljivo, где је
групи Menadzeri додељена
Read дозвола.
Корисник са корисничким именом Marko, који је члан групе Menadzeri, приступа датотеци
C:\\Documents\\Projekti.doc. Ефективна дозвола коју Marko има над овом датотеком је:"
a = "Full Control"
b = "Modify"
c = "Read"
d = "Write"
metadata/_custom_type_script = "uid://d11s7unngcflm"
