[resource]
script = ExtResource("1_p8l68")
question = "Рачунар који администрирате има проблема са повезивањем на мрежу. Да бисте
пронашли адресу било ког рачунара са којим рачунар има активну TCP везу ви ћете:"
a = "Из Windows Administrative Tools-а, отворићете Performance Monitor"
b = "У Control Panel-у, отворићете Network and Internet и селектовати Network and Sharing Center"
c = "Из Windows Administrative Tools-а, отворићете Resource Monitor"
d = "Отворићете Update and Security, изабрати Windows Security и селектоватиFirewall and Network protection"
metadata/_custom_type_script = "uid://d11s7unngcflm"
