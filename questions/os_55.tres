[resource]
script = ExtResource("1_ljf4m")
question = "Рачунари PC1 и PC2 повезани су у мрежу преко свича. Додељене су им адресе:

PC1: IP: 10.11.11.1 PC2: IP: 10.11.11.2
SM: 255.255.255.128 SM: 255.255.255.128
DG: 10.11.11.100 DG: 10.11.11.100

Када се са PC1 пингује PC2, пинг је успешан. Када се са PC2 пингује PC1 пинг није
успешан, за сва четири пакета пинга добија се одговор Request timed out.
Узрок тога што не ради пинг са PC2 на PC1 је:"
a = "унутар firewall-a на PC1 је конфигурисано правило које блокира ICMP пакетекоји долазе на рачунар"
b = "мрежни кабл којим је PC1 повезан на свич је неисправан"
c = "IP адресе овим рачунарима нису добро додељене"
d = "унутар firewall-a на PC2 је конфигурисано правило које блокира ICMP пакетекоји долазе на рачунар"
e = "мрежни кабл којим је PC2 повезан на свич је неисправан"
metadata/_custom_type_script = "uid://d11s7unngcflm"
