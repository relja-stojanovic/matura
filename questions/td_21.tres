script = ExtResource("1_stfw5")
question = "Анализом следећег текста:
„После сваке тачке, зареза и двотачке у тексту пише се размак ( један клик на SPACE тастер на тастатури ),након тога остатак текста.“ утврђено је да текст није написан правилно. Да би текст био правилно написан потребно је болдован текст заменити следећим исправним форматом:"
a = "размак( један клик на SPACE тастер на тастатури ),након тога"
b = "размак(један клик на SPACE тастер на тастатури), након тога"
c = "размак ( један клик на SPACE тастер на тастатури ) , након тога"
d = "размак (један клик на SPACE тастер на тастатури), након тога"
answer = Array[int]([3])
