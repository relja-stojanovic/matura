script = ExtResource("1_6r1d0")
question = "На слици је приказан међукорак приликом креирања партиције на Disk0-у. Новој партицији може да се придружи латинично слово енглеског алфабета:"
a = "Било које слово од А до Z"
b = "Само слово E како је приказано"
c = "Не сме слово C, сва остала слова могу"
d = "Не смеју C и D, сва остала слова могу"
answer = Array[int]([3])
