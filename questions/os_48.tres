[ext_resource type="Script" uid="uid://d11s7unngcflm" path="res://questions/Question.gd" id="1_h8xv7"]

[resource]
script = ExtResource("1_h8xv7")
question = "Купили сте рачунар са инсталираним Windows клијентским оперативним системом. Желите да модификујете систем тако да га прилагодите својим потребама. Међутим, желите да направите резервну копију система како бисте, ако се деси нешто непредвиђено, могли да вратите датотеке и претходна подешавања. Да бисте ово постигли потребно је да:"
a = "Направите резервну копију ваших датотека коришћењем дугмета Back Up Files уBackup And Restore Center."
b = "Направите слику (image) свог рачунара користећи Create а system image уBackup And Restore прозору за дијалог."
c = "Направите слику (image) свог рачунара користећи System Repair tool"
d = "Направите претходну верзију датотека користећи Shadow Copies"
answer = Array[int]([1])
metadata/_custom_type_script = "uid://d11s7unngcflm"
