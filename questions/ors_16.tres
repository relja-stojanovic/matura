[resource]
script = ExtResource("1_vlgbu")
question = "Радник техничке подршке прима позив и отвара налог. Док корисник објашњава симптоме квара, радник схвата да зна у чему је корисников проблем. Поступиће правилно ако уради следеће:"
a = "наставиће да слуша корисника а када заврши излагање, упутиће га на веб сајт за решење проблема"
b = "прекинуће корисника у излагању и објаснити му како да реши проблем"
c = "замолиће корисника да му неколико пута понови симптоме да би био сигуран"
d = "саслушаће корисниково излагање до краја а потом ће му објаснити како да реши проблем"
answer = Array[int]([3])
