[ext_resource type="Script" uid="uid://d11s7unngcflm" path="res://Question.gd" id="1_0ndng"]

[resource]
script = ExtResource("1_0ndng")
question = "Школски рачунарски кабинет има десет рачунара повезаних у мрежу која функционише исправно. Ученици се пријављују на ове рачунаре преко локалних корисничких налога ограничених привилегија. За реализацију вежбе ученицима су потребни оперативни системи на које ће се пријавити преко администраторског налога. У ту сврху креиране су виртуелне машине, по једна радна станица на сваком рачунару у кабинету. Ученици су конфигурисали виртуелне машине да тестирају дељење ресурса у мрежи равноправних рачунара. На виртуелној машини PC-1 креиран је фолдер NASTAVA за који су подешене следеће дозволе:

група/дозвола Sharing NTFS
Everyone Full control Read & execute

Тестирањем са осталих виртуелних машина ученици су установили да дељени фолдер није видљив. Могући узроци овог проблема су:"
a = "Помоћу тих виртуелних машина не може да се реализује описана мрежа"
b = "IP адресе виртуелних машина нису додељене тако да припадају истој мрежи"
c = "Sharing и NTFS дозволе за кориснике над фолдером нису добро подешене"
d = "Мрежна картица виртуелних машина није подешена да шаље податке у физичку мрежу"
answer = Array[int]([1, 3])
metadata/_custom_type_script = "uid://d11s7unngcflm"
