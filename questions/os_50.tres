[resource]
script = ExtResource("1_i6khj")
question = "Штампач Xerox Phaser 2030 који се користио у једној канцеларији треба пребацити у
други део пословне зграде и треба га оспособити да функционише као бежични
штампач. Штампач је повезан на напајање и укључен. Да би био функционалан
потребно је:"
a = "Инсталирати драјвер без повезивања кабла за пренос података јер ће сештампач користити преко бежичне везе"
b = "овезати кабл за пренос података између рачунара и штампача, инсталиратидрајвер и подесити га да обезбеди бежичну везу са рачунаром"
c = "Искључити штампач, драјвер може да се инсталира и када није укљученштампач јер се приликом инсталације драјвера неће користити"
answer = Array[int]([1])
