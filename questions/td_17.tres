[resource]
script = ExtResource("1_ucnyr")
question = "Техничко лице које израђује документацију попунило је Excel документ о подацима
радника у фирми. Након одређеног времена примећена је штампарска грешка: радник
је написано рандик на више места у документу. Најједноставније је преправити грешку
опцијом у програму:"
a = "Sort & Filter"
b = "Find & Select"
c = "Mеrge & Center"
d = "Wrap Text"
answer = Array[int]([1])
