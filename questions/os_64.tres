[resource]
script = ExtResource("1_dr3t4")
question = "Управо сте инсталирали нови оперативни систем унутар виртуелне машине.
Примећујете да се извршење задатака у оперативном систему хоста знатно успорило.
Да бисте повећали перформансе хоста:"
a = "инсталираћете више физичке меморије"
b = "повећаћете величину виртуелног чврстог диска"
c = "заменићете тренутни програм за виртуелизацију неким другим"
d = "смањићете физичку меморију додељену виртуелној машини"
e = "обрисаћете привремене датотеке виртуеле машине"
f = "инсталираћете додатне физичке чврсте дискове"
answer = Array[int]([0, 3])
