[resource]
script = ExtResource("1_4htc3")
question = "Ласерски колор штампач се користи за штампање фотографија, али корисници се жале
да штампање траје сувише дуго. Компонента штампача чијом надоградњом би се
најефикасније постигло убрзање штампања фотографија је:"
a = "мрежна картица"
b = "меморија"
c = "кертриџ"
d = "напајање"
answer = Array[int]([1])
