[ext_resource type="Script" uid="uid://d11s7unngcflm" path="res://questions/Question.gd" id="1_khsp1"]

[resource]
script = ExtResource("1_khsp1")
question = "Ана поседује директоријум који би желела да подели са другим корисницима на мрежи. У њему се налази и фајл под називом baza.xlsx. Ана би хтела да обезбеди да овом фајлу може истовремено приступити само један корисник. Разлог је њено настојање да се спречи могућност да неки корисник избрише измене које је у фајлу извршио неки други корисник који је у исто време конектован на поменути фајл. Да бисте ово обезбедили:"
a = "Треба ограничити број корисника који могу приступити заједничкомдиректоријуму, на само једног корисника."
b = "Атрибут фајла baza.xlsx треба конфигурисати као недељен (unshared)."
c = "Треба конфигурисати распоред рада тако да корисници приступају поменутомфајлу у различито време."
d = "У File Explorer – у конфигурисати заједнички директоријум, тако да корисницима не допустити приступ наведеном фајлу у offline режиму."
metadata/_custom_type_script = "uid://d11s7unngcflm"
