script = ExtResource("1_cqhqa")
question = "Сумњате да неко покушава да приступи рачунарима употребљавајући ваљана корисичка имена и више покушаја да погоди лозинку. Да бисте пратили такву активност потребно је да конфигуришете следећу политику надзора:"
a = "Login Event failures"
b = "Directory Service Access failures"
c = "Privilege Use sucess"
d = "Account Login Event failures"
e = "Acount Management failures"
