script = ExtResource("1_h8xv7")
question = "Пошиљалац који жели да пошаље електронски документ меилом, и да при томе буде загарантована аутентичност пошиљаоца, интегритет поруке и обезбеђена немогућност порицања одговорности, примениће:"
a = "одложено слање у време после поноћи"
b = "проверу документа антивирус програмом"
c = "дигитални потпис на електронски документ"
d = "компресију документа раровањем"
e = "слање непромењеног документа меилом"
answer = Array[int]([2])
