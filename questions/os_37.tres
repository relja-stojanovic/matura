[resource]
script = ExtResource("1_xd0fq")
question = "Корисник вам се обраћа за помоћ у вези са лаптоп рачунаром. Након ажурирања
Windows оперативног система, корисник више не може да користи одређене локално
повезане уређаје, а поновно покретање није решило проблем. Да бисте решили
проблем ви ћете:"
a = "онемогућити услугу Windows Update"
b = "проверите да ли постоје ажурирања"
c = "обновити скривена ажурирања"
d = "вратити ажурирања у претходно стање"
answer = Array[int]([2])
metadata/_custom_type_script = "uid://d11s7unngcflm"
