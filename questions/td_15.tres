[resource]
script = ExtResource("1_er4il")
question = "Приликом цртања дела техничке документације појавила се потреба за креирањем
новог симбола. Симбол је нацртан помоћу линија и стрелица различитих дебљина. Да
би симбол могао поново да се користи у истом фајлу потребно је:"
a = "снимити тај фајл на радну површину"
b = "груписати све елементе симбола"
c = "обојити све елементе симбола црвено"
answer = Array[int]([1])
