script = ExtResource("1_er4il")
question = "На приказаној шеми где је DIN дигитални улаз микрорачунара. Шта се догађа када тастер није притиснут?"
a = "Отпорник R на дигиталном улазу обезбеђује логичку"
b = "Отпорник R на дигиталном улазу обезбеђује логичку „1“"
c = "Отпорник R на дигиталном улазу обезбеђује пад напона"
