[ext_resource type="Script" uid="uid://d11s7unngcflm" path="res://Question.gd" id="1_khsp1"]

[resource]
script = ExtResource("1_khsp1")
question = "Милан је члан групе ПРОДАЈА, која поседује пуну дозволу (Full Control) за приступ заједничком директоријуму ПРОДАЈА. Поред тога, Милан има индивидуалну дозволу Read за приступ овом директоријуму. Ипак, када покуша да приступи заједничком директоријуму ПРОДАЈА, добија поруку да му је приступ забрањен. За решење овог проблема :"
a = "Треба избрисати Миланове индивидуалне дозволе за директоријум ПРОДАЈА."
b = "Милану треба доделити одговарајућу дозволу за Full Control приступ задиректоријум ПРОДАЈА.."
c = "Треба проверити да ли је Милан члан неке од група којима је експлицитноукинута дозвола за приступ директоријуму ПРОДАЈА."
d = "Треба обрисати (уклонити) све дозволе које су додељене групи ПРОДАЈА, па их"
answer = Array[int]([2])
